# ── Production Environment Template ─────────────────────
# Copy to .env and fill in secrets before deploying

# ── Database ────────────────────────────────────────────
POSTGRES_DB=dental_flow
POSTGRES_USER=dental_flow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=https://app.dentalflow.com

# ── Client ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api

# ── Twilio ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# ── AI Providers ────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Observability ───────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Scaling ─────────────────────────────────────────────
SERVER_REPLICAS=2

# ── Ports ───────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
