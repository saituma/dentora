# ──────────────────────────────────────
# Dental Flow — Environment Configuration
# Copy to .env and fill in values
# ──────────────────────────────────────

# ─── General ──────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# ─── Database ─────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dental_flow

# ─── Redis ────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ───────────────
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Twilio ──────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# ─── LLM Providers ──────────────
OPENAI_API_KEY=
OPENAI_ORG_ID=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ─── Speech-to-Text ─────────────
DEEPGRAM_API_KEY=
ASSEMBLY_AI_API_KEY=
GOOGLE_STT_API_KEY=

# ─── Text-to-Speech ─────────────
ELEVENLABS_API_KEY=
GOOGLE_TTS_API_KEY=
AZURE_TTS_KEY=
AZURE_TTS_REGION=

# ─── Storage ────────────────────
RECORDING_STORAGE_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ─── Observability ──────────────
SENTRY_DSN=
OTEL_EXPORTER_ENDPOINT=
