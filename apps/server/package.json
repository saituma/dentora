{
  "name": "@repo/server",
  "private": true,
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "simulate:twilio": "tsx scripts/simulate-twilio-webhooks.ts",
    "simulate:twilio:media": "tsx scripts/simulate-twilio-media-stream.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/instrumentation-express": "^0.60.0",
    "@opentelemetry/instrumentation-http": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-metrics": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-node": "^2.5.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@repo/shared": "workspace:*",
    "@types/pdfkit": "^0.17.5",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.1",
    "cors": "latest",
    "dotenv": "latest",
    "drizzle-orm": "latest",
    "express": "latest",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "morgan": "^1.10.1",
    "multer": "1.4.5-lts.2",
    "nanoid": "^5.1.6",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.18.0",
    "pg": "latest",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "stripe": "^22.0.2",
    "twilio": "^5.6.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.12",
    "@types/node": "latest",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "latest",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.9",
    "tsx": "latest",
    "typescript": "latest"
  }
}
