# Omit trailing /api — the client normalizes to .../api automatically.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Sentry (https://sentry.io) — client + server component errors; set Alerts in the project to get email/Slack.
NEXT_PUBLIC_SENTRY_DSN=
# Optional: separate env label (defaults to VERCEL_ENV or NODE_ENV)
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# Optional: release string (e.g. git SHA from CI)
# NEXT_PUBLIC_SENTRY_RELEASE=
# Source maps in production builds (also set SENTRY_ORG, SENTRY_PROJECT in CI)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
